# 知识库与大模型配置（本地）
# 知识库来源可以是目录或单文件
KB_SOURCE_PATH="F:\\个人知识库\\02-学习\\04-赵逍遥AI课"

# API 服务端口
API_PORT="8787"

# RAG 检索参数
RAG_TOP_K="4"
RAG_MIN_SCORE="1.1"
RAG_MIN_TOKEN_MATCHES="2"
RAG_MIN_TOKEN_COVERAGE="0.28"
RAG_MIN_VECTOR_SCORE="0.30"
RAG_VECTOR_WEIGHT="8"
RAG_VECTOR_DIM="256"
# true = 命中知识库后也走大模型生成；false = 直接返回知识库片段
RAG_USE_LLM_ON_HIT="true"

# 未命中知识库时的大模型配置（SiliconFlow OpenAI Chat Completions）
LLM_API_URL="https://api.siliconflow.cn/v1/chat/completions"
LLM_API_KEY=""
LLM_MODEL="deepseek-ai/DeepSeek-R1-0528-Qwen3-8B"
LLM_API_FORMAT="openai-chat"
LLM_AUTH_HEADER="Authorization"
LLM_AUTH_SCHEME="Bearer"
