# 知识库与大模型配置（本地）
# 知识库来源可填“目录”或“单个文件”
KB_SOURCE_PATH="F:\\个人知识库\\02-学习\\04-赵逍遥AI课"
# API 服务端口
API_PORT="8787"

# RAG 检索参数
RAG_TOP_K="4"
RAG_MIN_SCORE="1.1"
RAG_MIN_TOKEN_MATCHES="2"
# true = 命中知识库后也走大模型生成；false = 直接返回知识库片段回答
RAG_USE_LLM_ON_HIT="false"

# 未命中知识库时的 HTTP 模型配置
LLM_API_URL=""
LLM_API_KEY=""
LLM_MODEL="gpt-4.1-mini"
# 可选: openai-chat / openai-responses
LLM_API_FORMAT="openai-chat"
# 可选: Authorization / api-key
LLM_AUTH_HEADER="Authorization"
LLM_AUTH_SCHEME="Bearer"
